#!/usr/bin/env bash
#
# pybuild
#   builds static or dynamically linked Python, always static ssl/crypto
#
# desc:
#   - script to configure and build python, makes tar.zst
#   - last tested with python 3.13 line, openssl 3.0 line
#   - has some hardcoded paths, confined to variables
#
# args:
#   - arg1: whether to build 'static' or 'dynamic' interpreter
#
# static-note:
#   - static build is truly static (unlike python-standalone project)
#   - caveat: still dlopens libnss_foo.so.2 at runtime
#   - see https://sourceware.org/glibc/wiki/FAQ "Even statically linked..."
#   - no soname/api changes in libnss_* for many years
#   - therefore, works on any glibc linux, tested back to rhel6
#   - should also work on alpine/musl with gcompat pkg and copied libnss_*
#   - works at least for creating a static vim build with python support
#   - causes problems with some pypi packages that do compiles (gcloud, numpy)
#   - todo: link to hand-built glibc with --enable-static-nss as in glibc faq
#   - todo: test on musl as above
#
# Scott Mcdermott <scott@smemsh.net>
# https://github.com/smemsh/utiladm/
# https://spdx.org/licenses/GPL-2.0
#

set -e
trap_err () { echo "$FUNCNAME: code $1, line: $2, cmd: \"$3\""; exit $1; }
trap 'trap_err $? $LINENO "$BASH_COMMAND"' ERR

relocroot=`mktemp -d`
chmod 0755 $relocroot
trap_exit () { (($1 == 0)) && rm -rf ${relocroot:?}; }
trap 'trap_exit $?' EXIT

set -o pipefail

[[ ${PWD##*/} == cpython ]]
[[ ${1:?} =~ ^(static|dynamic)$ ]]

buildtype=$1
ncpus=`nproc`
arch=`arch`
arch=${arch/x86_64/amd64}
arch=${arch/aarch64/arm64}

if source /etc/lsb-release &>/dev/null
then [[ $DISTRIB_ID == Ubuntu ]] &&
	osver=u${DISTRIB_RELEASE%.*}
else f=/etc/redhat-release; test -f $f &&
	osver=rhel$(awk '{FS = "."; $0 = $3; print $1}' $f)
fi
[[ $osver ]]

case $buildtype in
(static) pydirbase=/opt/pystatic;;
(dynamic) pydirbase=/opt/python;;
esac

ssldirbase=/opt/openssl
pkgdepot=~/tarbin

pyver=$(git describe --tags | awk -F ^v '{print $2}')
pydir=$pydirbase-$pyver
pymmver=${pyver%.*}

sslver=$(ls -1d $ssldirbase* | sort -rV | head -1 | awk -F - '{print $2}')
ssldir=$ssldirbase-$sslver

logtime=`date +%Y%m%d%H%M%S`
logstr=$buildtype-$pyver-$logtime

pkgbase=python-${pyver}_${buildtype}_staticssl-${sslver}_opt_${arch}_${osver}

###

buildwatch ()
{
	if [[ $DEBUG == 1 ]]; then cat; return; fi
	pv -bntl 2>&1 >|${1:?}-$logstr.log | while read secs lines
	do printf "%s\t\t\t\t\r" "$1: ${lines} lines in ${secs%.*}s"
	done; echo
	ln -nsf $1-$logstr.log $1.log
}

configure ()
{
	local staticlto

	env_static=(
		LDFLAGS="'-static -static-libgcc'"
		CFLAGS=-fPIC
		LDSHARED=gcc
		LINKFORSHARED=
	)
	env_dynamic=()
	env_common=()
	declare -n envref=env_$buildtype

	###

	conf_common=(
		--prefix=$pydir
		--with-openssl=$ssldir
		--with-ensurepip=install
		--with-static-libpython
		--enable-optimizations
		--disable-ipv6
		--disable-shared
		--disable-test-modules
	)
	conf_dynamic=(
		--with-lto=full
		--enable-loadable-sqlite-extensions
	)
	[[ $osver == u18 ]] && staticlto=no || staticlto=full
	conf_static=(
		--with-lto=$staticlto
	)
	declare -n confref=conf_$buildtype

	###

	eval \
		"${env_common[@]}" "${envref[@]}" \
		./configure \
		"${conf_common[@]}" "${confref[@]}" \
	|& buildwatch configure

	cp config.log config-$logstr.log
}

mutate ()
{
	printf mutate...

	# otherwise it uses only one cpu, with gcc.  apparently this does not
	# happen with clang (untested).  using a more recent Make (as of
	# 20260320, v4.4.1 was most recent, which we tried) was supposed to
	# fix this and use the Make job server, but didn't. TODO use clang
	#
	sed -i s,-flto,-flto=auto,g Makefile.pre

	echo done
}

setup ()
{
	local ncinc nclibs

	# this is only relevant for the static build.  dynamic build also
	# links statically but uses its own logic hardcoded for lib/ so
	# openssl build *must* do "ln -s lib64 lib" in ssl basedir
	# TODO file issue upstream
	#
	for libdir in lib{64,}
	do if test -d $ssldir/$libdir; then slib=$libdir; break; fi; done
	[[ $slib ]]

	cryptolibs=(
		-l:libcrypto.a -Wl,--exclude-libs,libcrypto.a
		-l:libz.a -Wl,--exclude-libs,libz.a
	)
	sslinc=(
		-I$ssldir/include
	)
	sslld=(
		-L$ssldir/$slib
	)
	ssllibs=(
		-l:libssl.a -Wl,--exclude-libs,libssl.a
		${cryptolibs[@]}
	)

	#

	sslrule=(
		_ssl{,.c}
		${sslinc[@]}
		${sslld[@]}
		${ssllibs[@]}
		${cryptolibs[@]}
	)
	hashlibrule=(
		_hash{lib,openssl.c}
		${sslinc[@]}
		${sslld[@]}
		${cryptolibs[@]}
	)
	sqlite3rule=(
		_sqlite3
		$(cd Modules; echo _sqlite/*.c)
		-l:libsqlite3.a
	)
	zstdrule=(
		_zstd
		$(cd Modules; echo _zstd/*.c)
		-l:libzstd.a
	)

	###

	nclibs='-ltinfo'
	if [[ $osver == u18 ]]; then
		ncinc=-I/usr/include/ncursesw    # ncurses <= 5
		rules_static+=(-e '/^_dbm\>/d')  # no libgdbm_compat.a
		nclibs+=$'\x20-lgpm'             # too bad u18 needs it
		sslrule+=(-ldl)                  # must be after libcrypto
	fi
	rules_static=(
		-e '0,/^\*shared\*$/s,shared,static,'
		-e '/^_hashlib/a\' -e "${sqlite3rule[*]}"
		-e '/^\*shared\*$/d'
		-e '/^readline\>/s,termcap,tinfo,'
		-e "s%^_zstd\\>.*%${zstdrule[*]}%"
		-e "s%^_ssl\\>.*%${sslrule[*]}%"
		-e "s%^_hashlib\\>.*%${hashlibrule[*]}%"
		-e "/^_curses\\>/s,(-lncurses).*-ltermcap,$ncinc \\1w $nclibs,"
		-e "/^_curses_panel\\>/s,(-lpanel),$ncinc \\1w $nclibs,"
		-e "/^_curses_panel\\>/s,(-lncurses),\\1w $nclibs,"
		-e '/^_test/d'
	)
	rules_common=(
		-e '/^nis\>/d'
		-e '/^_uuid\>/s,(-luuid),-I/usr/include/uuid \1,'
		-e '/^_tkinter\>/d'
		-e '/^\*disabled\*$/a\' -e 'nis\n_tkinter\nspwd'
		#-e "s,^(_testcapi\\>.*),\\1 $(echo _testcapi/*.c),"
		#-e '/^_testsinglephase\>/a\'
		#-e '_testclinic _testclinic.c'
	)
	rules_dynamic=(
	)
	declare -n rulesref=rules_$buildtype

	###

	if [[ $buildtype == dynamic ]]
	then echo skipped; return; fi

	cd Modules
	sed -n -r 's/^#([a-z_\*].*)$/\1/p' Setup >| Setup.local
	[[ $DEBUG == 1 ]] && set -x
	sed -i -r "${rulesref[@]}" "${rules_common[@]}" Setup.local
	set +x
	cp Setup.local Setup-$logstr.local
	cd ..
}

build ()
{
	local pylib straylib
	local added out

	make -j$ncpus \
	|& buildwatch build

	printf "addlibs: "
	pylib=libpython$pymmver.a
	test -f $pylib

	for straylib in $(find Modules/ -name '*.a'); do
		ar -M <<- %
			open $pylib
			addlib $straylib
			save
			end
		%
		printf "${straylib##*/} "
		let ++added
	done
	((added == 0)) && out=done || ranlib $pylib
	echo $out
}

package ()
{
	make DESTDIR=$relocroot install \
	|& buildwatch install

	tar -C $relocroot \
		-cvaf $pkgdepot/$pkgbase.tar.zst \
		--owner=0 --group=0 \
		opt \
	|& buildwatch package
}

main ()
{
	printf "building $buildtype python: $pyver, "
	printf "openssl: $sslver, "
	printf "cores: $ncpus"
	echo

	printf cleanup...
	make distclean &>/dev/null || true
	echo done

	configure
	mutate
	setup
	build
	package

	echo "build completed in ${SECONDS}s"
}

main "$@"
